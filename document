export const getTrendingMovies = async () => {
    try {
        const response = await fetch(`${BASE_URL}/trending/movie/day?api_key=${NEXT_PUBLIC_ACCESS_TOKEN}`);
        const data = await response.json();
        return data.results;
    } catch (error) {
        console.error('Token Error:', error);
        return [];
    }
};



